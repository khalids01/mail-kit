AUTH_SESSION_COOKIE_NAME=better-auth.session_token
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=http://localhost:5006/success?checkout_id={CHECKOUT_ID}
CORS_ORIGIN=http://localhost:5006
DATABASE_URL=postgresql://root:admin@localhost:5432/mailkit
REDIS_URL=redis://localhost:6379
