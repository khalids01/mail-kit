# Example Mailu engine env for docker.maulu-setup.yml.
# The real file should be deploy/mailu.env and can be generated with:
#   DOMAIN=example.com MAIL_HOST=mail.example.com ./scripts/mailu-setup.sh

# Persistent Mailu data. Back this directory up.
ROOT=/opt/mailu

# Mailu image version. Keep this aligned with the official Mailu docs/setup utility.
VERSION=2024.06

# Random secret for Mailu sessions. Generate with:
#   openssl rand -hex 16
SECRET_KEY=replace-with-random-secret

# Docker network used by Mailu.
SUBNET=192.168.203.0/24
BIND_ADDRESS4=0.0.0.0
BIND_ADDRESS6=

# Main mail domain and host.
DOMAIN=example.com
HOSTNAMES=mail.example.com
POSTMASTER=postmaster

# For a normal VPS, Mailu can request certificates itself.
TLS_FLAVOR=letsencrypt

# Conservative first-test limits.
AUTH_RATELIMIT=10/minute
MESSAGE_RATELIMIT=200/day

# Required for Mail Kit engine provisioning.
API=true
WEB_API=/api
API_TOKEN=replace-with-a-long-random-token

# Mail Kit is the product UI, so do not expose webmail to users.
WEBMAIL=none
WEBDAV=none
ANTIVIRUS=clamav

# Basic service toggles.
DISABLE_STATISTICS=True
ADMIN=true
IMAP=true
POP3=false
SITENAME=Mail Kit Mail Engine

# Mailu provides:
#   SMTP submission: mail.example.com:587
#   IMAP over TLS:   mail.example.com:993
#   API:             https://mail.example.com/api
#
# Keep Mailu admin/webmail private if possible. Users should only use Mail Kit.
