# Generate the real Mailu env/compose with the official Mailu setup utility.
# This file records the values Mail Kit expects for the first one-VPS test.

DOMAIN=example.com
HOSTNAMES=mail.example.com
POSTMASTER=postmaster
TLS_FLAVOR=letsencrypt
AUTH_RATELIMIT=10/minute
MESSAGE_RATELIMIT=200/day
API=true
WEB_API=/api
API_TOKEN=replace-with-a-long-random-token

# Mailu should provide SMTP submission and IMAP to Mail Kit:
# SMTP submission: mail.example.com:587
# IMAP over TLS:   mail.example.com:993
#
# Keep Mailu admin/webmail private if possible. Users should only use Mail Kit.
