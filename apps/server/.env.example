SMTP_PORT=1025

# Production Mailu engine integration.
# SMTP_HOST/SMTP_PORT should point at Mailu submission SMTP in production.
MAIL_ENGINE_API_URL=
MAIL_ENGINE_API_TOKEN=
MAIL_ENGINE_IMAP_HOST=
MAIL_ENGINE_IMAP_PORT=993
MAIL_ENGINE_IMAP_SECURE=true
MAIL_ENGINE_SYNC_ENABLED=false
MAIL_ENGINE_SYNC_INTERVAL_SECONDS=300
MAIL_ENGINE_SEND_RATE_LIMIT_PER_MINUTE=60
